WHERE source_id = ?
AND remote_track_id = ?
ORDER BY downloaded_audio.downloaded_at_epoch_millis DESC
LIMIT 1;

selectDownloadedAudio:
SELECT *
FROM downloaded_audio
WHERE source_id = ?
ORDER BY downloaded_audio.downloaded_at_epoch_millis DESC;

selectAllDownloadedAudio:
