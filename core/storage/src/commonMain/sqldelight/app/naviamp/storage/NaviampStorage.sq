FROM keep_downloaded_collection_track
WHERE source_id = ?
AND collection_kind = ?
AND collection_id = ?;

selectKeepDownloadedTrackIdsForOtherPolicies:
SELECT DISTINCT remote_track_id
FROM keep_downloaded_collection_track
WHERE source_id = ?
AND (collection_kind != ? OR collection_id != ?);

deleteKeepDownloadedCollectionTracks:
DELETE FROM keep_downloaded_collection_track
WHERE source_id = ?
AND collection_kind = ?
AND collection_id = ?;

insertKeepDownloadedCollectionTrack:
INSERT OR IGNORE INTO keep_downloaded_collection_track(
