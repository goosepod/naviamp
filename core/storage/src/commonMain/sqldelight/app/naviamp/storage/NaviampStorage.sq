  audio_bit_depth,
  audio_sampling_rate_hz,
  favorited_at_iso8601,
  user_rating,
  downloaded_at_epoch_millis
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteDownloadedAudio:
