insertPendingProviderAction:
INSERT INTO pending_provider_action(
  source_id,
  action_type,
  entity_id,
  bool_value,
  long_value,
  created_at_epoch_millis,
  last_attempt_at_epoch_millis,
  attempt_count,
  last_error
) VALUES (?, ?, ?, ?, ?, ?, NULL, 0, NULL);

selectPendingProviderActions:
SELECT *
FROM pending_provider_action
WHERE source_id = ?
ORDER BY created_at_epoch_millis ASC, id ASC
LIMIT ?;

deletePendingProviderAction:
DELETE FROM pending_provider_action
WHERE id = ?;

deletePendingProviderActionsForEntity:
DELETE FROM pending_provider_action
WHERE source_id = ?
AND action_type = ?
AND entity_id = ?;

markPendingProviderActionFailed:
UPDATE pending_provider_action
SET attempt_count = attempt_count + 1,
last_attempt_at_epoch_millis = ?,
last_error = ?
WHERE id = ?;

pendingProviderActionCount:
SELECT COUNT(*) FROM pending_provider_action;

failedPendingProviderActionCount:
SELECT COUNT(*) FROM pending_provider_action
WHERE attempt_count > 0;

