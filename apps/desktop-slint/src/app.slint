                                }
                            }
                        }
                    }
                }

                if root.current-route != "player": Rectangle {
                    height: 74px;
                    border-color: #1cffffff;
                    border-width: 0px;
                    border-radius: 0px;
                    background: #30000000;

                    mini-player-touch := TouchArea {
                        clicked => {
                            root.current-route = "player";
                            root.route-requested("player");
                        }
                    }

                    VerticalLayout {
                        padding: 6px;
                        spacing: 4px;

                        HorizontalLayout {
                            spacing: 10px;
                            Rectangle {
                                width: 48px;
                                height: 48px;
                                border-radius: 5px;
                                border-width: 0px;
                                border-color: transparent;
                                background: #28000000;
                                clip: true;

                                Image {
                                    source: root.now-playing-art;
                                    image-fit: cover;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }
                            VerticalLayout {
                                spacing: 3px;
                                Text { text: root.now-playing-title; color: #f5f7fb; font-size: 15px; font-weight: 700; overflow: elide; }
                                Text { text: root.now-playing-subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                Text { text: root.playback-status-text; color: #c9d1dc; font-size: 11px; overflow: elide; }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: end;
                                PlayerIconButton { label: "previous"; icon-source: @image-url("../assets/icons/previous.svg"); clicked => { root.playback-previous-requested(); } }
                                if root.playback-is-playing: PlayerIconButton { label: "pause"; icon-source: @image-url("../assets/icons/pause.svg"); active: true; clicked => { root.playback-pause-requested(); } }
                                if !root.playback-is-playing: PlayerIconButton { label: "play"; icon-source: @image-url("../assets/icons/play.svg"); active: true; clicked => { root.playback-resume-requested(); } }
                                PlayerIconButton { label: "next"; icon-source: @image-url("../assets/icons/next.svg"); clicked => { root.playback-next-requested(); } }
                            }
                        }
                    }
                }

                if root.current-route != "player": Rectangle {
                    height: 44px;
                    background: #28000000;

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 4px;
                        NavButton { label: "Home"; short-label: "home"; icon-source: @image-url("../assets/icons/home.svg"); route: "home"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                        NavButton { label: "Playlists"; short-label: "playlists"; icon-source: @image-url("../assets/icons/playlist.svg"); route: "playlists"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                        NavButton { label: "Library"; short-label: "library"; icon-source: @image-url("../assets/icons/library.svg"); route: "library"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                        NavButton { label: "Search"; short-label: "search"; icon-source: @image-url("../assets/icons/search.svg"); route: "search"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                        NavButton { label: "Radio"; short-label: "radio"; icon-source: @image-url("../assets/icons/radio.svg"); route: "radio"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                        NavButton { label: "Downloads"; short-label: "downloads"; icon-source: @image-url("../assets/icons/downloads.svg"); route: "downloads"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                        NavButton { label: "Settings"; short-label: "settings"; icon-source: @image-url("../assets/icons/settings.svg"); route: "settings"; current-route: root.current-route; collapsed: true; clicked(route) => { root.current-route = route; root.route-requested(route); } }
                    }
                }
            }
        }
    }
}
