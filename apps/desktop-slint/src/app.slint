                                        height: 64px;
                                        border-radius: 5px;
                                        background: up-next-touch.pressed ? #36ffffff : up-next-touch.has-hover ? #22000000 : #12000000;
                                        up-next-touch := TouchArea { clicked => { root.queue-row-activated(row.source_index); } }
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            spacing: 10px;
                                            Rectangle { width: 34px; height: 34px; border-radius: 4px; background: #28000000; }
                                            VerticalLayout {
                                                spacing: 3px;
                                                Text { text: row.title; color: #f5f7fb; font-size: 13px; font-weight: 700; overflow: elide; }
                                                Text { text: row.subtitle; color: #d7cadf; font-size: 12px; overflow: elide; }
                                            }
                                            Image { source: @image-url("../assets/icons/menu.svg"); image-fit: contain; width: 18px; height: 18px; opacity: 0.72; }
                                        }
                                    }
                                }

                                if root.show-track-details: Rectangle {
                                    height: 86px;
                                    border-radius: 6px;
                                    background: #18000000;
                                    Text { text: root.now-playing-details; color: #d8dee8; font-size: 12px; overflow: elide; x: 10px; y: 10px; width: parent.width - 20px; }
                                }
                            }
                        }
                    }

                    if root.width >= 560px && root.width < 780px: VerticalLayout {
                        padding: 8px;
                        spacing: 8px;
                        alignment: center;

                        HorizontalLayout {
                            spacing: 14px;
                            alignment: center;

                            Image {
                                source: root.now-playing-art;
                                image-fit: contain;
                                width: root.height < 600px ? 238px : 286px;
                                height: root.height < 600px ? 238px : 286px;
                            }

                            VerticalLayout {
                                spacing: root.height < 600px ? 5px : 8px;
                                alignment: center;

                                Text { text: root.now-playing-title; color: #f5f7fb; font-size: 24px; font-weight: 700; horizontal-alignment: center; overflow: elide; }

                                HorizontalLayout {
                                    spacing: 8px;
                                    Rectangle {
                                        height: 32px;
                                        border-radius: 3px;
                                        background: #20ffffff;
                                        Text { text: root.now-playing-artist; color: #f5f7fb; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                                    }
                                    Rectangle {
                                        height: 32px;
                                        border-radius: 3px;
                                        background: #20ffffff;
                                        Text { text: root.now-playing-album; color: #f5f7fb; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                                    }
                                }

                                Text { text: "Year " + root.now-playing-year + "  -  " + root.now-playing-codec-line; color: #d7cadf; font-size: 13px; horizontal-alignment: center; overflow: elide; }
                                Text { text: root.playback-status-text; color: root.player-accent; font-size: 13px; horizontal-alignment: center; overflow: elide; }

                                HorizontalLayout {
                                    spacing: 8px;
                                    Text { text: root.playback-elapsed-text; color: #d7cadf; width: 42px; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                                    Slider {
                                        minimum: 0;
