import { Button, LineEdit, ListView, Slider } from "std-widgets.slint";

component PlayerIconButton inherits Rectangle {
    in property <string> label;
    in property <length> button-width: 46px;
    in property <bool> active: false;
    callback clicked();

    width: root.button-width;
    height: 46px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? #5ac8fa : #343b46;
    background: touch.pressed ? #2f4356 : touch.has-hover ? #253342 : root.active ? #1d3345 : #20242b;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.active ? #dff5ff : #f5f7fb;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export struct MediaRow {
    kind: string,
    title: string,
    subtitle: string,
    source_index: int,
}

export struct SourceRow {
    title: string,
    subtitle: string,
    source_index: int,
}

export component AppWindow inherits Window {
    title: "Naviamp";
    preferred-width: 1100px;
    preferred-height: 760px;
    min-width: 860px;
    min-height: 600px;
    resize-border-width: 8px;
    background: #121417;

    in-out property <string> server-url;
    in-out property <string> username;
    in-out property <string> password;
    in-out property <string> query;
    in-out property <float> volume: 80;
    in-out property <float> playback-progress: 0;
    in property <string> status-text: "Ready";
    in property <string> error-text: "";
    in property <string> playback-status-text: "Idle";
    in property <string> playback-elapsed-text: "0:00";
    in property <string> playback-duration-text: "--:--";
    in property <string> now-playing-title: "Nothing playing";
    in property <string> now-playing-subtitle: "";
    in property <image> now-playing-art;
    in property <bool> playback-is-playing: false;
    in property <[MediaRow]> media-rows;
    in property <[SourceRow]> sources;

    callback connect-requested(string, string, string);
    callback source-activated(int);
    callback source-delete-requested(int);
    callback search-requested(string);
    callback radio-requested();
    callback row-activated(string, int);
    callback playback-pause-requested();
    callback playback-resume-requested();
    callback playback-previous-requested();
    callback playback-next-requested();
    callback playback-shuffle-requested();
    callback volume-changed(float);
    callback playback-seek-requested(float);
    callback error-dismissed();

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        Text {
            text: "Naviamp";
            color: #f5f7fb;
            font-size: 28px;
            font-weight: 700;
        }

        Rectangle {
            height: 1px;
            background: #2b3038;
        }

        if root.error-text != "": Rectangle {
            height: 44px;
            border-radius: 6px;
            border-width: 1px;
            border-color: #7b3941;
            background: #2a171b;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 8px;

                Text {
                    text: root.error-text;
                    color: #ffd4d9;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Button {
                    text: "Dismiss";
                    clicked => { root.error-dismissed(); }
                }
            }
        }

        if root.sources.length > 0: Rectangle {
            height: 92px;
            border-color: #2b3038;
            border-width: 1px;
            border-radius: 6px;
            background: #171a1f;

            ListView {
                for source in root.sources: Rectangle {
                    height: 44px;
                    background: source-touch.pressed ? #263241 : source-touch.has-hover ? #202833 : #171a1f;

                    source-touch := TouchArea {
                        clicked => { root.source-activated(source.source_index); }
                    }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        spacing: 8px;

                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: source.title;
                                color: #f5f7fb;
                                font-size: 13px;
                                overflow: elide;
                            }
                            Text {
                                text: source.subtitle;
                                color: #9ba7b5;
                                font-size: 11px;
                                overflow: elide;
                            }
                        }

                        Button {
                            text: "Delete";
                            clicked => { root.source-delete-requested(source.source_index); }
                        }
                    }
                }
            }
        }

        GridLayout {
            spacing: 8px;
            Row {
                Text { text: "Server"; color: #b8c0cc; vertical-alignment: center; }
                LineEdit { text <=> root.server-url; placeholder-text: "https://music.example.com"; }
            }
            Row {
                Text { text: "User"; color: #b8c0cc; vertical-alignment: center; }
                LineEdit { text <=> root.username; placeholder-text: "username"; }
            }
            Row {
                Text { text: "Password"; color: #b8c0cc; vertical-alignment: center; }
                LineEdit {
                    text <=> root.password;
                    placeholder-text: "password";
                    input-type: InputType.password;
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Button {
                text: "Save Connection";
                clicked => { root.connect-requested(root.server-url, root.username, root.password); }
            }
            Text {
                text: root.status-text;
                color: #9ba7b5;
                vertical-alignment: center;
            }
        }

        Rectangle {
            height: 132px;
            border-color: #2b3038;
            border-width: 1px;
            border-radius: 6px;
            background: #15191f;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                HorizontalLayout {
                    spacing: 12px;

                    Rectangle {
                        width: 76px;
                        height: 76px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #364152;
                        background: #243041;
                        clip: true;

                        Image {
                            source: root.now-playing-art;
                            image-fit: cover;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    VerticalLayout {
                        spacing: 5px;
                        Text {
                            text: root.now-playing-title;
                            color: #f5f7fb;
                            font-size: 18px;
                            font-weight: 700;
                            overflow: elide;
                        }
                        Text {
                            text: root.now-playing-subtitle;
                            color: #9ba7b5;
                            font-size: 12px;
                            overflow: elide;
                        }
                        Text {
                            text: root.playback-status-text;
                            color: #7fc7e8;
                            font-size: 12px;
                            overflow: elide;
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        alignment: end;

                        PlayerIconButton {
                            label: "<<";
                            clicked => { root.playback-previous-requested(); }
                        }

                        if root.playback-is-playing: PlayerIconButton {
                            label: "||";
                            active: true;
                            clicked => { root.playback-pause-requested(); }
                        }

                        if !root.playback-is-playing: PlayerIconButton {
                            label: ">";
                            active: true;
                            clicked => { root.playback-resume-requested(); }
                        }

                        PlayerIconButton {
                            label: ">>";
                            clicked => { root.playback-next-requested(); }
                        }

                        PlayerIconButton {
                            label: "Shuffle";
                            button-width: 74px;
                            clicked => { root.playback-shuffle-requested(); }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: root.playback-elapsed-text;
                        color: #9ba7b5;
                        width: 42px;
                        vertical-alignment: center;
                    }
                    Slider {
                        minimum: 0;
                        maximum: 100;
                        value <=> root.playback-progress;
                        released(value) => { root.playback-seek-requested(value); }
                    }
                    Text {
                        text: root.playback-duration-text;
                        color: #9ba7b5;
                        width: 48px;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Volume";
                        color: #9ba7b5;
                        width: 58px;
                        vertical-alignment: center;
                    }
                    Slider {
                        minimum: 0;
                        maximum: 100;
                        value <=> root.volume;
                        changed => { root.volume-changed(root.volume); }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            LineEdit {
                text <=> root.query;
                placeholder-text: "Search tracks";
                accepted => { root.search-requested(root.query); }
            }
            Button {
                text: "Search";
                clicked => { root.search-requested(root.query); }
            }
            Button {
                text: "Radio";
                clicked => { root.radio-requested(); }
            }
        }

        Rectangle {
            border-color: #2b3038;
            border-width: 1px;
            border-radius: 6px;
            background: #171a1f;

            ListView {
                for row in root.media-rows: Rectangle {
                    height: 58px;
                    background: row-touch.pressed ? #263241 : row-touch.has-hover ? #202833 : #171a1f;

                    row-touch := TouchArea {
                        clicked => { root.row-activated(row.kind, row.source_index); }
                    }

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        spacing: 3px;
                        Text {
                            text: row.title;
                            color: #f5f7fb;
                            font-size: 15px;
                            overflow: elide;
                        }
                        Text {
                            text: row.subtitle;
                            color: #9ba7b5;
                            font-size: 12px;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }
}
