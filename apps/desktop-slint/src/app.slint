import { Button, LineEdit, ListView, Slider } from "std-widgets.slint";

component PlayerIconButton inherits Rectangle {
    in property <string> label;
    in property <image> icon-source;
    in property <length> button-width: 46px;
    in property <bool> active: false;
    callback clicked();

    width: root.button-width;
    height: 46px;
    border-radius: 23px;
    border-width: 0px;
    border-color: transparent;
    background: touch.pressed ? #40ffffff : touch.has-hover ? #24ffffff : root.active ? #35ffffff : transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Image {
        source: root.icon-source;
        image-fit: contain;
        width: 22px;
        height: 22px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component NavButton inherits Rectangle {
    in property <string> label;
    in property <string> short-label;
    in property <image> icon-source;
    in property <string> route;
    in property <string> current-route;
    in property <bool> collapsed: false;
    callback clicked(string);

    height: 46px;
    border-radius: 0px;
    background: transparent;

    touch := TouchArea {
        clicked => { root.clicked(root.route); }
    }

    Image {
        source: root.icon-source;
        image-fit: contain;
        width: 21px;
        height: 21px;
        opacity: root.current-route == root.route ? 1.0 : 0.58;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

export struct MediaRow {
    kind: string,
    title: string,
    subtitle: string,
    source_index: int,
    is_header: bool,
    action_label: string,
}

export struct SourceRow {
    title: string,
    subtitle: string,
    source_index: int,
}

export component AppWindow inherits Window {
    title: "Naviamp";
    icon: @image-url("../assets/naviamp.png");
    preferred-width: 806px;
    preferred-height: 660px;
    min-width: 328px;
    min-height: 560px;
    resize-border-width: 8px;
    background: root.background-start;

    in-out property <string> server-url;
    in-out property <string> username;
    in-out property <string> password;
    in-out property <string> query;
    in-out property <string> current-route: "search";
    in-out property <bool> nav-collapsed: false;
    in-out property <float> volume: 80;
    in-out property <float> playback-progress: 0;
    in property <string> status-text: "Ready";
    in property <string> error-text: "";
    in property <string> search-state-text: "";
    in property <string> detail-title: "";
    in property <string> detail-subtitle: "";
    in property <string> playback-status-text: "Idle";
    in property <string> playback-elapsed-text: "0:00";
    in property <string> playback-duration-text: "--:--";
    in property <string> now-playing-title: "Nothing playing";
    in property <string> now-playing-subtitle: "";
    in property <string> now-playing-artist: "";
    in property <string> now-playing-album: "";
    in property <string> now-playing-year: "--";
    in property <string> now-playing-codec-line: "--";
    in property <string> now-playing-details: "";
    in property <image> now-playing-art;
    in property <color> player-accent: #7fc7e8;
    in property <color> player-surface: #15191f;
    in property <color> background-start: #273242;
    in property <color> background-mid: #232c39;
    in property <color> background-end: #25131e;
    in property <bool> now-playing-favorite: false;
    in property <int> now-playing-rating: 0;
    in property <bool> playback-is-playing: false;
    in-out property <bool> show-track-details: false;
    in-out property <bool> show-player-menu: false;
    in property <[float]> visualizer-levels;
    in property <[MediaRow]> media-rows;
    in property <[MediaRow]> up-next-rows;
    in property <[MediaRow]> back-to-rows;
    in property <[SourceRow]> sources;

    callback connect-requested(string, string, string);
    callback source-activated(int);
    callback source-delete-requested(int);
    callback home-requested();
    callback home-library-radio-requested();
    callback home-random-album-radio-requested();
    callback playlists-refresh-requested();
    callback playlist-create-requested(string);
    callback playlist-rename-requested(string);
    callback playlist-delete-requested();
    callback playlist-play-requested();
    callback playlist-add-current-requested();
    callback library-sync-requested();
    callback library-clear-requested();
    callback library-filter-requested(string);
    callback library-letter-requested(string);
    callback search-requested(string);
    callback radio-requested();
    callback row-activated(string, int);
    callback row-action-requested(string, int, string);
    callback album-play-requested();
    callback album-radio-requested();
    callback artist-radio-requested();
    callback playback-pause-requested();
    callback playback-resume-requested();
    callback playback-previous-requested();
    callback playback-next-requested();
    callback playback-shuffle-requested();
    callback volume-changed(float);
    callback playback-seek-requested(float);
    callback now-playing-favorite-requested();
    callback now-playing-rating-requested(int);
    callback now-playing-link-requested(string);
    callback queue-row-activated(int);
    callback error-dismissed();
    callback route-requested(string);
    callback back-requested();

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 0px;
            clip: true;
            background: transparent;

            VerticalLayout {
                padding: 14px;
                spacing: 12px;

                if root.current-route != "player": HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: root.nav-collapsed ? "N" : "Naviamp";
                        color: #f5f7fb;
                        font-size: root.nav-collapsed ? 20px : 24px;
                        font-weight: 700;
                        horizontal-alignment: root.nav-collapsed ? center : left;
                    }
                    Button {
                        text: root.nav-collapsed ? ">" : "<";
                        clicked => { root.nav-collapsed = !root.nav-collapsed; }
                    }
                }

                Rectangle { height: 1px; background: #2b3038; }

                NavButton {
                    label: "Home";
                    short-label: "H";
                    route: "home";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Search";
                    short-label: "S";
                    route: "search";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Library";
                    short-label: "L";
                    route: "library";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Playlists";
                    short-label: "P";
                    route: "playlists";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Radio";
                    short-label: "R";
                    route: "radio";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Downloads";
                    short-label: "D";
                    route: "downloads";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Settings";
                    short-label: "T";
                    route: "settings";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Now Playing";
                    short-label: "N";
                    route: "player";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
            }
        }

        Rectangle {
            background: @linear-gradient(128deg, root.background-start 0%, root.background-mid 52%, root.background-end 100%);

            VerticalLayout {
                padding: 4px;
                spacing: 8px;

                HorizontalLayout {
                    height: 34px;
                    spacing: 8px;
                    Button {
                        text: "<";
                        clicked => { root.back-requested(); }
                    }
                    Text {
                        text: root.current-route == "player" ? "Now Playing" :
                            root.current-route == "album-detail" ? "Album" :
                            root.current-route == "artist-detail" ? "Artist" :
                            root.current-route == "radio" ? "Internet Radio" :
                            root.current-route == "library" ? "Library" :
                            root.current-route == "playlists" ? "Playlists" :
                            root.current-route == "playlist-detail" ? "Playlist" :
                            root.current-route == "downloads" ? "Downloads" :
                            root.current-route == "settings" ? "Settings" :
                            root.current-route == "home" ? "Home" : "Search";
                        color: #f5f7fb;
                        font-size: 20px;
                        font-weight: 700;
                    }
                    Text {
                        text: root.status-text;
                        color: #9ba7b5;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                if root.error-text != "": Rectangle {
                    height: 44px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #7b3941;
                    background: #2a171b;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        spacing: 8px;

                        Text {
                            text: root.error-text;
                            color: #ffd4d9;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Button {
                            text: "Dismiss";
                            clicked => { root.error-dismissed(); }
                        }
                    }
                }

                if root.current-route == "search": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "Search tracks";
                            accepted => { root.search-requested(root.query); }
                        }
                        Button {
                            text: "Search";
                            clicked => { root.search-requested(root.query); }
                        }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : search-row-touch.pressed ? #36ffffff : search-row-touch.has-hover ? #22000000 : #12000000;

                                search-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 3px;
                                        Text {
                                            text: row.title;
                                            color: row.is_header ? #7fc7e8 : #f5f7fb;
                                            font-size: row.is_header ? 12px : 15px;
                                            font-weight: row.is_header ? 700 : 400;
                                            overflow: elide;
                                        }
                                        if !row.is_header: Text {
                                            text: row.subtitle;
                                            color: #9ba7b5;
                                            font-size: 12px;
                                            overflow: elide;
                                        }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "album-detail": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: root.detail-title; color: #f5f7fb; font-size: 20px; font-weight: 700; overflow: elide; }
                            Text { text: root.detail-subtitle; color: #9ba7b5; font-size: 13px; overflow: elide; }
                        }
                        Button {
                            text: "Play Album";
                            clicked => { root.album-play-requested(); }
                        }
                        Button {
                            text: "Album Radio";
                            clicked => { root.album-radio-requested(); }
                        }
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : album-row-touch.pressed ? #36ffffff : album-row-touch.has-hover ? #22000000 : #12000000;

                                album-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "artist-detail": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: root.detail-title; color: #f5f7fb; font-size: 20px; font-weight: 700; overflow: elide; }
                            Text { text: root.detail-subtitle; color: #9ba7b5; font-size: 13px; overflow: elide; }
                        }
                        Button {
                            text: "Artist Radio";
                            clicked => { root.artist-radio-requested(); }
                        }
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : artist-row-touch.pressed ? #36ffffff : artist-row-touch.has-hover ? #22000000 : #12000000;

                                artist-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "radio": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "Load Radio";
                            clicked => { root.radio-requested(); }
                        }
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: 58px;
                                background: radio-row-touch.pressed ? #36ffffff : radio-row-touch.has-hover ? #22000000 : #12000000;

                                radio-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                VerticalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    padding-top: 8px;
                                    spacing: 3px;
                                    Text { text: row.title; color: #f5f7fb; font-size: 15px; overflow: elide; }
                                    Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "settings": VerticalLayout {
                    spacing: 12px;

                    Rectangle {
                        height: root.sources.length > 0 ? 92px : 0px;
                        border-color: #18ffffff;
                        border-width: root.sources.length > 0 ? 1px : 0px;
                        border-radius: 6px;
                        background: transparent;

                        if root.sources.length > 0: ListView {
                            for source in root.sources: Rectangle {
                                height: 44px;
                                background: source-touch.pressed ? #36ffffff : source-touch.has-hover ? #22000000 : #12000000;

                                source-touch := TouchArea {
                                    clicked => { root.source-activated(source.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 2px;
                                        Text { text: source.title; color: #f5f7fb; font-size: 13px; overflow: elide; }
                                        Text { text: source.subtitle; color: #9ba7b5; font-size: 11px; overflow: elide; }
                                    }

                                    Button {
                                        text: "Delete";
                                        clicked => { root.source-delete-requested(source.source_index); }
                                    }
                                }
                            }
                        }
                    }

                    GridLayout {
                        spacing: 8px;
                        Row {
                            Text { text: "Server"; color: #b8c0cc; vertical-alignment: center; }
                            LineEdit { text <=> root.server-url; placeholder-text: "https://music.example.com"; }
                        }
                        Row {
                            Text { text: "User"; color: #b8c0cc; vertical-alignment: center; }
                            LineEdit { text <=> root.username; placeholder-text: "username"; }
                        }
                        Row {
                            Text { text: "Password"; color: #b8c0cc; vertical-alignment: center; }
                            LineEdit {
                                text <=> root.password;
                                placeholder-text: "password";
                                input-type: InputType.password;
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "Save Connection";
                            clicked => { root.connect-requested(root.server-url, root.username, root.password); }
                        }
                    }
                }

                if root.current-route == "home": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Button { text: "Refresh Home"; clicked => { root.home-requested(); } }
                        Button { text: "Library Radio"; clicked => { root.home-library-radio-requested(); } }
                        Button { text: "Random Album Radio"; clicked => { root.home-random-album-radio-requested(); } }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : home-row-touch.pressed ? #36ffffff : home-row-touch.has-hover ? #22000000 : #12000000;
                                home-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "library": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "Filter local library";
                            accepted => { root.library-filter-requested(root.query); }
                        }
                        Button { text: "Filter"; clicked => { root.library-filter-requested(root.query); } }
                        Button { text: "Sync"; clicked => { root.library-sync-requested(); } }
                        Button { text: "Clear"; clicked => { root.library-clear-requested(); } }
                    }
                    HorizontalLayout {
                        spacing: 4px;
                        Button { text: "All"; clicked => { root.library-letter-requested(""); } }
                        Button { text: "0-9"; clicked => { root.library-letter-requested("0-9"); } }
                        Button { text: "#"; clicked => { root.library-letter-requested("#"); } }
                        Button { text: "A"; clicked => { root.library-letter-requested("A"); } }
                        Button { text: "B"; clicked => { root.library-letter-requested("B"); } }
                        Button { text: "C"; clicked => { root.library-letter-requested("C"); } }
                        Button { text: "D"; clicked => { root.library-letter-requested("D"); } }
                        Button { text: "E"; clicked => { root.library-letter-requested("E"); } }
                        Button { text: "F"; clicked => { root.library-letter-requested("F"); } }
                        Button { text: "G"; clicked => { root.library-letter-requested("G"); } }
                        Button { text: "H"; clicked => { root.library-letter-requested("H"); } }
                        Button { text: "I"; clicked => { root.library-letter-requested("I"); } }
                        Button { text: "J"; clicked => { root.library-letter-requested("J"); } }
                        Button { text: "K"; clicked => { root.library-letter-requested("K"); } }
                        Button { text: "L"; clicked => { root.library-letter-requested("L"); } }
                        Button { text: "M"; clicked => { root.library-letter-requested("M"); } }
                        Button { text: "N"; clicked => { root.library-letter-requested("N"); } }
                        Button { text: "O"; clicked => { root.library-letter-requested("O"); } }
                        Button { text: "P"; clicked => { root.library-letter-requested("P"); } }
                        Button { text: "Q"; clicked => { root.library-letter-requested("Q"); } }
                        Button { text: "R"; clicked => { root.library-letter-requested("R"); } }
                        Button { text: "S"; clicked => { root.library-letter-requested("S"); } }
                        Button { text: "T"; clicked => { root.library-letter-requested("T"); } }
                        Button { text: "U"; clicked => { root.library-letter-requested("U"); } }
                        Button { text: "V"; clicked => { root.library-letter-requested("V"); } }
                        Button { text: "W"; clicked => { root.library-letter-requested("W"); } }
                        Button { text: "X"; clicked => { root.library-letter-requested("X"); } }
                        Button { text: "Y"; clicked => { root.library-letter-requested("Y"); } }
                        Button { text: "Z"; clicked => { root.library-letter-requested("Z"); } }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : library-row-touch.pressed ? #36ffffff : library-row-touch.has-hover ? #22000000 : #12000000;
                                library-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "playlists": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "New playlist name";
                            accepted => { root.playlist-create-requested(root.query); }
                        }
                        Button { text: "Create"; clicked => { root.playlist-create-requested(root.query); } }
                        Button { text: "Refresh"; clicked => { root.playlists-refresh-requested(); } }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : playlist-row-touch.pressed ? #36ffffff : playlist-row-touch.has-hover ? #22000000 : #12000000;
                                playlist-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "playlist-detail": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: root.detail-title; color: #f5f7fb; font-size: 20px; font-weight: 700; overflow: elide; }
                            Text { text: root.detail-subtitle; color: #9ba7b5; font-size: 13px; overflow: elide; }
                        }
                        Button { text: "Play Playlist"; clicked => { root.playlist-play-requested(); } }
                        Button { text: "Add Current"; clicked => { root.playlist-add-current-requested(); } }
                        Button { text: "Rename"; clicked => { root.playlist-rename-requested(root.query); } }
                        Button { text: "Delete"; clicked => { root.playlist-delete-requested(); } }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "Playlist name";
                            accepted => { root.playlist-rename-requested(root.query); }
                        }
                    }
                    Rectangle {
                        border-color: #18ffffff;
                        border-width: 1px;
                        border-radius: 6px;
                        background: transparent;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #14000000 : playlist-detail-row-touch.pressed ? #36ffffff : playlist-detail-row-touch.has-hover ? #22000000 : #12000000;
                                playlist-detail-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "downloads": Rectangle {
                    border-color: #18ffffff;
                    border-width: 1px;
                    border-radius: 6px;
                    background: transparent;

                    VerticalLayout {
                        padding: 18px;
                        spacing: 8px;
                        Text {
                            text: root.current-route == "home" ? "Home will surface albums, playlists, and history." :
                                root.current-route == "library" ? "Library browsing will land here after the local index is wired." :
                                root.current-route == "playlists" ? "Playlist list and detail routes will land here." :
                                "Downloads and offline cache controls will land here.";
                            color: #b8c0cc;
                            font-size: 14px;
                            overflow: elide;
                        }
                    }
                }

                if root.current-route == "player": Rectangle {
                    border-width: 0px;
                    background: @linear-gradient(128deg, root.background-start 0%, root.background-mid 55%, root.background-end 100%);

                    if root.width >= 780px: HorizontalLayout {
                        padding: 4px;
                        spacing: 8px;

                        VerticalLayout {
                            width: 360px;
                            spacing: 8px;
                            alignment: center;

                            Image {
                                source: root.now-playing-art;
                                image-fit: contain;
                                height: 350px;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: root.playback-elapsed-text; color: #f5f7fb; width: 42px; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                                Slider {
                                    minimum: 0;
                                    maximum: 100;
                                    value <=> root.playback-progress;
                                    released(value) => { root.playback-seek-requested(value); }
                                }
                                Text { text: root.playback-duration-text; color: #f5f7fb; width: 42px; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            }

                            Text { text: root.now-playing-title; color: #f5f7fb; font-size: 16px; font-weight: 700; horizontal-alignment: center; overflow: elide; }
                            Text { text: root.now-playing-artist; color: #d7cadf; font-size: 13px; horizontal-alignment: center; overflow: elide; }
                            Text { text: root.now-playing-album + " (" + root.now-playing-year + ")"; color: #d7cadf; font-size: 13px; horizontal-alignment: center; overflow: elide; }

                            HorizontalLayout {
                                spacing: 6px;
                                alignment: center;
                                Text { text: root.now-playing-favorite ? "♥" : "♡"; color: #e8edf5; font-size: 18px; vertical-alignment: center; }
                                Text { text: root.now-playing-rating >= 1 ? "★" : "☆"; color: #e8edf5; font-size: 18px; }
                                Text { text: root.now-playing-rating >= 2 ? "★" : "☆"; color: #e8edf5; font-size: 18px; }
                                Text { text: root.now-playing-rating >= 3 ? "★" : "☆"; color: #e8edf5; font-size: 18px; }
                                Text { text: root.now-playing-rating >= 4 ? "★" : "☆"; color: #e8edf5; font-size: 18px; }
                                Text { text: root.now-playing-rating >= 5 ? "★" : "☆"; color: #e8edf5; font-size: 18px; }
                            }

                            Text { text: root.now-playing-codec-line; color: #d7cadf; font-size: 11px; horizontal-alignment: center; overflow: elide; }

                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: "VOL"; color: #d7cadf; width: 40px; font-size: 11px; vertical-alignment: center; }
                                Slider {
                                    minimum: 0;
                                    maximum: 100;
                                    value <=> root.volume;
                                    changed(value) => { root.volume-changed(value); }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: center;
                                PlayerIconButton { label: "shuffle"; icon-source: @image-url("../assets/icons/shuffle.svg"); button-width: 34px; clicked => { root.playback-shuffle-requested(); } }
                                PlayerIconButton { label: "previous"; icon-source: @image-url("../assets/icons/previous.svg"); button-width: 34px; clicked => { root.playback-previous-requested(); } }
                                if root.playback-is-playing: PlayerIconButton { label: "pause"; icon-source: @image-url("../assets/icons/pause.svg"); active: true; clicked => { root.playback-pause-requested(); } }
                                if !root.playback-is-playing: PlayerIconButton { label: "play"; icon-source: @image-url("../assets/icons/play.svg"); active: true; clicked => { root.playback-resume-requested(); } }
                                PlayerIconButton { label: "next"; icon-source: @image-url("../assets/icons/next.svg"); button-width: 34px; clicked => { root.playback-next-requested(); } }
                                PlayerIconButton { label: "repeat"; icon-source: @image-url("../assets/icons/repeat.svg"); button-width: 34px; clicked => { } }
                            }

                            HorizontalLayout {
                                spacing: 18px;
                                alignment: center;
                                PlayerIconButton { label: "radio"; icon-source: @image-url("../assets/icons/radio.svg"); button-width: 34px; clicked => { } }
                                PlayerIconButton { label: "playlist"; icon-source: @image-url("../assets/icons/playlist.svg"); button-width: 34px; clicked => { root.playlist-add-current-requested(); } }
                                PlayerIconButton { label: "collapse"; icon-source: @image-url("../assets/icons/back.svg"); button-width: 34px; clicked => { root.current-route = "home"; root.route-requested("home"); } }
                                PlayerIconButton { label: "lyrics"; icon-source: @image-url("../assets/icons/lyrics.svg"); button-width: 34px; clicked => { root.show-track-details = !root.show-track-details; } }
                                PlayerIconButton { label: "menu"; icon-source: @image-url("../assets/icons/menu.svg"); button-width: 34px; clicked => { root.show-player-menu = !root.show-player-menu; } }
                            }
                        }

                        Rectangle {
                            border-radius: 8px;
                            background: #12000000;

                            VerticalLayout {
                                padding: 10px;
                                spacing: 8px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    Text { text: "BACK TO"; color: #d7cadf; font-size: 12px; font-weight: 700; horizontal-alignment: center; }
                                    Rectangle {
                                        height: 36px;
                                        border-radius: 18px;
                                        background: #26ffffff;
                                        Text { text: "UP NEXT"; color: #f5f7fb; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "RELATED"; color: #d7cadf; font-size: 12px; font-weight: 700; horizontal-alignment: center; }
                                }

                                ListView {
