import { Button, LineEdit, ListView, Slider } from "std-widgets.slint";

component PlayerIconButton inherits Rectangle {
    in property <string> label;
    in property <length> button-width: 46px;
    in property <bool> active: false;
    callback clicked();

    width: root.button-width;
    height: 46px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? #5ac8fa : #343b46;
    background: touch.pressed ? #2f4356 : touch.has-hover ? #253342 : root.active ? #1d3345 : #20242b;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.active ? #dff5ff : #f5f7fb;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component NavButton inherits Rectangle {
    in property <string> label;
    in property <string> short-label;
    in property <string> route;
    in property <string> current-route;
    in property <bool> collapsed: false;
    callback clicked(string);

    height: 38px;
    border-radius: 6px;
    background: root.current-route == root.route ? #253342 : touch.pressed ? #202b37 : touch.has-hover ? #1c242d : transparent;

    touch := TouchArea {
        clicked => { root.clicked(root.route); }
    }

    Text {
        text: root.collapsed ? root.short-label : root.label;
        color: root.current-route == root.route ? #f5f7fb : #9ba7b5;
        font-size: 13px;
        font-weight: root.current-route == root.route ? 700 : 400;
        horizontal-alignment: root.collapsed ? center : left;
        vertical-alignment: center;
        x: root.collapsed ? 0px : 12px;
        width: parent.width;
    }
}

export struct MediaRow {
    kind: string,
    title: string,
    subtitle: string,
    source_index: int,
    is_header: bool,
    action_label: string,
}

export struct SourceRow {
    title: string,
    subtitle: string,
    source_index: int,
}

export component AppWindow inherits Window {
    title: "Naviamp";
    icon: @image-url("../assets/naviamp.png");
    preferred-width: 1100px;
    preferred-height: 760px;
    min-width: 860px;
    min-height: 600px;
    resize-border-width: 8px;
    background: #121417;

    in-out property <string> server-url;
    in-out property <string> username;
    in-out property <string> password;
    in-out property <string> query;
    in-out property <string> current-route: "search";
    in-out property <bool> nav-collapsed: false;
    in-out property <float> volume: 80;
    in-out property <float> playback-progress: 0;
    in property <string> status-text: "Ready";
    in property <string> error-text: "";
    in property <string> search-state-text: "";
    in property <string> detail-title: "";
    in property <string> detail-subtitle: "";
    in property <string> playback-status-text: "Idle";
    in property <string> playback-elapsed-text: "0:00";
    in property <string> playback-duration-text: "--:--";
    in property <string> now-playing-title: "Nothing playing";
    in property <string> now-playing-subtitle: "";
    in property <string> now-playing-artist: "";
    in property <string> now-playing-album: "";
    in property <string> now-playing-year: "--";
    in property <string> now-playing-codec-line: "--";
    in property <string> now-playing-details: "";
    in property <image> now-playing-art;
    in property <color> player-accent: #7fc7e8;
    in property <color> player-surface: #15191f;
    in property <bool> now-playing-favorite: false;
    in property <int> now-playing-rating: 0;
    in property <bool> playback-is-playing: false;
    in-out property <bool> show-track-details: false;
    in-out property <bool> show-player-menu: false;
    in property <[float]> visualizer-levels;
    in property <[MediaRow]> media-rows;
    in property <[MediaRow]> up-next-rows;
    in property <[MediaRow]> back-to-rows;
    in property <[SourceRow]> sources;

    callback connect-requested(string, string, string);
    callback source-activated(int);
    callback source-delete-requested(int);
    callback home-requested();
    callback home-library-radio-requested();
    callback home-random-album-radio-requested();
    callback playlists-refresh-requested();
    callback playlist-create-requested(string);
    callback playlist-rename-requested(string);
    callback playlist-delete-requested();
    callback playlist-play-requested();
    callback playlist-add-current-requested();
    callback library-sync-requested();
    callback library-clear-requested();
    callback library-filter-requested(string);
    callback library-letter-requested(string);
    callback search-requested(string);
    callback radio-requested();
    callback row-activated(string, int);
    callback row-action-requested(string, int, string);
    callback album-play-requested();
    callback album-radio-requested();
    callback artist-radio-requested();
    callback playback-pause-requested();
    callback playback-resume-requested();
    callback playback-previous-requested();
    callback playback-next-requested();
    callback playback-shuffle-requested();
    callback volume-changed(float);
    callback playback-seek-requested(float);
    callback now-playing-favorite-requested();
    callback now-playing-rating-requested(int);
    callback now-playing-link-requested(string);
    callback queue-row-activated(int);
    callback error-dismissed();
    callback route-requested(string);
    callback back-requested();

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: root.nav-collapsed ? 74px : 188px;
            background: #101318;

            VerticalLayout {
                padding: 14px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: root.nav-collapsed ? "N" : "Naviamp";
                        color: #f5f7fb;
                        font-size: root.nav-collapsed ? 20px : 24px;
                        font-weight: 700;
                        horizontal-alignment: root.nav-collapsed ? center : left;
                    }
                    Button {
                        text: root.nav-collapsed ? ">" : "<";
                        clicked => { root.nav-collapsed = !root.nav-collapsed; }
                    }
                }

                Rectangle { height: 1px; background: #2b3038; }

                NavButton {
                    label: "Home";
                    short-label: "H";
                    route: "home";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Search";
                    short-label: "S";
                    route: "search";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Library";
                    short-label: "L";
                    route: "library";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Playlists";
                    short-label: "P";
                    route: "playlists";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Radio";
                    short-label: "R";
                    route: "radio";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Downloads";
                    short-label: "D";
                    route: "downloads";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Settings";
                    short-label: "T";
                    route: "settings";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
                NavButton {
                    label: "Now Playing";
                    short-label: "N";
                    route: "player";
                    current-route: root.current-route;
                    collapsed: root.nav-collapsed;
                    clicked(route) => {
                        root.current-route = route;
                        root.route-requested(route);
                    }
                }
            }
        }

        Rectangle {
            background: #121417;

            VerticalLayout {
                padding: 18px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 12px;
                    Button {
                        text: "Back";
                        clicked => { root.back-requested(); }
                    }
                    Text {
                        text: root.current-route == "player" ? "Now Playing" :
                            root.current-route == "album-detail" ? "Album" :
                            root.current-route == "artist-detail" ? "Artist" :
                            root.current-route == "radio" ? "Internet Radio" :
                            root.current-route == "library" ? "Library" :
                            root.current-route == "playlists" ? "Playlists" :
                            root.current-route == "playlist-detail" ? "Playlist" :
                            root.current-route == "downloads" ? "Downloads" :
                            root.current-route == "settings" ? "Settings" :
                            root.current-route == "home" ? "Home" : "Search";
                        color: #f5f7fb;
                        font-size: 24px;
                        font-weight: 700;
                    }
                    Text {
                        text: root.status-text;
                        color: #9ba7b5;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                if root.error-text != "": Rectangle {
                    height: 44px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #7b3941;
                    background: #2a171b;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        spacing: 8px;

                        Text {
                            text: root.error-text;
                            color: #ffd4d9;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Button {
                            text: "Dismiss";
                            clicked => { root.error-dismissed(); }
                        }
                    }
                }

                if root.current-route == "search": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "Search tracks";
                            accepted => { root.search-requested(root.query); }
                        }
                        Button {
                            text: "Search";
                            clicked => { root.search-requested(root.query); }
                        }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : search-row-touch.pressed ? #263241 : search-row-touch.has-hover ? #202833 : #171a1f;

                                search-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 3px;
                                        Text {
                                            text: row.title;
                                            color: row.is_header ? #7fc7e8 : #f5f7fb;
                                            font-size: row.is_header ? 12px : 15px;
                                            font-weight: row.is_header ? 700 : 400;
                                            overflow: elide;
                                        }
                                        if !row.is_header: Text {
                                            text: row.subtitle;
                                            color: #9ba7b5;
                                            font-size: 12px;
                                            overflow: elide;
                                        }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "album-detail": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: root.detail-title; color: #f5f7fb; font-size: 20px; font-weight: 700; overflow: elide; }
                            Text { text: root.detail-subtitle; color: #9ba7b5; font-size: 13px; overflow: elide; }
                        }
                        Button {
                            text: "Play Album";
                            clicked => { root.album-play-requested(); }
                        }
                        Button {
                            text: "Album Radio";
                            clicked => { root.album-radio-requested(); }
                        }
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : album-row-touch.pressed ? #263241 : album-row-touch.has-hover ? #202833 : #171a1f;

                                album-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "artist-detail": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: root.detail-title; color: #f5f7fb; font-size: 20px; font-weight: 700; overflow: elide; }
                            Text { text: root.detail-subtitle; color: #9ba7b5; font-size: 13px; overflow: elide; }
                        }
                        Button {
                            text: "Artist Radio";
                            clicked => { root.artist-radio-requested(); }
                        }
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : artist-row-touch.pressed ? #263241 : artist-row-touch.has-hover ? #202833 : #171a1f;

                                artist-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "radio": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "Load Radio";
                            clicked => { root.radio-requested(); }
                        }
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: 58px;
                                background: radio-row-touch.pressed ? #263241 : radio-row-touch.has-hover ? #202833 : #171a1f;

                                radio-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }

                                VerticalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    padding-top: 8px;
                                    spacing: 3px;
                                    Text { text: row.title; color: #f5f7fb; font-size: 15px; overflow: elide; }
                                    Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "settings": VerticalLayout {
                    spacing: 12px;

                    Rectangle {
                        height: root.sources.length > 0 ? 92px : 0px;
                        border-color: #2b3038;
                        border-width: root.sources.length > 0 ? 1px : 0px;
                        border-radius: 6px;
                        background: #171a1f;

                        if root.sources.length > 0: ListView {
                            for source in root.sources: Rectangle {
                                height: 44px;
                                background: source-touch.pressed ? #263241 : source-touch.has-hover ? #202833 : #171a1f;

                                source-touch := TouchArea {
                                    clicked => { root.source-activated(source.source_index); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        spacing: 2px;
                                        Text { text: source.title; color: #f5f7fb; font-size: 13px; overflow: elide; }
                                        Text { text: source.subtitle; color: #9ba7b5; font-size: 11px; overflow: elide; }
                                    }

                                    Button {
                                        text: "Delete";
                                        clicked => { root.source-delete-requested(source.source_index); }
                                    }
                                }
                            }
                        }
                    }

                    GridLayout {
                        spacing: 8px;
                        Row {
                            Text { text: "Server"; color: #b8c0cc; vertical-alignment: center; }
                            LineEdit { text <=> root.server-url; placeholder-text: "https://music.example.com"; }
                        }
                        Row {
                            Text { text: "User"; color: #b8c0cc; vertical-alignment: center; }
                            LineEdit { text <=> root.username; placeholder-text: "username"; }
                        }
                        Row {
                            Text { text: "Password"; color: #b8c0cc; vertical-alignment: center; }
                            LineEdit {
                                text <=> root.password;
                                placeholder-text: "password";
                                input-type: InputType.password;
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "Save Connection";
                            clicked => { root.connect-requested(root.server-url, root.username, root.password); }
                        }
                    }
                }

                if root.current-route == "home": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Button { text: "Refresh Home"; clicked => { root.home-requested(); } }
                        Button { text: "Library Radio"; clicked => { root.home-library-radio-requested(); } }
                        Button { text: "Random Album Radio"; clicked => { root.home-random-album-radio-requested(); } }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : home-row-touch.pressed ? #263241 : home-row-touch.has-hover ? #202833 : #171a1f;
                                home-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "library": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "Filter local library";
                            accepted => { root.library-filter-requested(root.query); }
                        }
                        Button { text: "Filter"; clicked => { root.library-filter-requested(root.query); } }
                        Button { text: "Sync"; clicked => { root.library-sync-requested(); } }
                        Button { text: "Clear"; clicked => { root.library-clear-requested(); } }
                    }
                    HorizontalLayout {
                        spacing: 4px;
                        Button { text: "All"; clicked => { root.library-letter-requested(""); } }
                        Button { text: "0-9"; clicked => { root.library-letter-requested("0-9"); } }
                        Button { text: "#"; clicked => { root.library-letter-requested("#"); } }
                        Button { text: "A"; clicked => { root.library-letter-requested("A"); } }
                        Button { text: "B"; clicked => { root.library-letter-requested("B"); } }
                        Button { text: "C"; clicked => { root.library-letter-requested("C"); } }
                        Button { text: "D"; clicked => { root.library-letter-requested("D"); } }
                        Button { text: "E"; clicked => { root.library-letter-requested("E"); } }
                        Button { text: "F"; clicked => { root.library-letter-requested("F"); } }
                        Button { text: "G"; clicked => { root.library-letter-requested("G"); } }
                        Button { text: "H"; clicked => { root.library-letter-requested("H"); } }
                        Button { text: "I"; clicked => { root.library-letter-requested("I"); } }
                        Button { text: "J"; clicked => { root.library-letter-requested("J"); } }
                        Button { text: "K"; clicked => { root.library-letter-requested("K"); } }
                        Button { text: "L"; clicked => { root.library-letter-requested("L"); } }
                        Button { text: "M"; clicked => { root.library-letter-requested("M"); } }
                        Button { text: "N"; clicked => { root.library-letter-requested("N"); } }
                        Button { text: "O"; clicked => { root.library-letter-requested("O"); } }
                        Button { text: "P"; clicked => { root.library-letter-requested("P"); } }
                        Button { text: "Q"; clicked => { root.library-letter-requested("Q"); } }
                        Button { text: "R"; clicked => { root.library-letter-requested("R"); } }
                        Button { text: "S"; clicked => { root.library-letter-requested("S"); } }
                        Button { text: "T"; clicked => { root.library-letter-requested("T"); } }
                        Button { text: "U"; clicked => { root.library-letter-requested("U"); } }
                        Button { text: "V"; clicked => { root.library-letter-requested("V"); } }
                        Button { text: "W"; clicked => { root.library-letter-requested("W"); } }
                        Button { text: "X"; clicked => { root.library-letter-requested("X"); } }
                        Button { text: "Y"; clicked => { root.library-letter-requested("Y"); } }
                        Button { text: "Z"; clicked => { root.library-letter-requested("Z"); } }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : library-row-touch.pressed ? #263241 : library-row-touch.has-hover ? #202833 : #171a1f;
                                library-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "playlists": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "New playlist name";
                            accepted => { root.playlist-create-requested(root.query); }
                        }
                        Button { text: "Create"; clicked => { root.playlist-create-requested(root.query); } }
                        Button { text: "Refresh"; clicked => { root.playlists-refresh-requested(); } }
                    }
                    if root.search-state-text != "": Text {
                        text: root.search-state-text;
                        color: #9ba7b5;
                        font-size: 13px;
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : playlist-row-touch.pressed ? #263241 : playlist-row-touch.has-hover ? #202833 : #171a1f;
                                playlist-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "playlist-detail": VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: root.detail-title; color: #f5f7fb; font-size: 20px; font-weight: 700; overflow: elide; }
                            Text { text: root.detail-subtitle; color: #9ba7b5; font-size: 13px; overflow: elide; }
                        }
                        Button { text: "Play Playlist"; clicked => { root.playlist-play-requested(); } }
                        Button { text: "Add Current"; clicked => { root.playlist-add-current-requested(); } }
                        Button { text: "Rename"; clicked => { root.playlist-rename-requested(root.query); } }
                        Button { text: "Delete"; clicked => { root.playlist-delete-requested(); } }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit {
                            text <=> root.query;
                            placeholder-text: "Playlist name";
                            accepted => { root.playlist-rename-requested(root.query); }
                        }
                    }
                    Rectangle {
                        border-color: #2b3038;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #171a1f;

                        ListView {
                            for row in root.media-rows: Rectangle {
                                height: row.is_header ? 34px : 58px;
                                background: row.is_header ? #121821 : playlist-detail-row-touch.pressed ? #263241 : playlist-detail-row-touch.has-hover ? #202833 : #171a1f;
                                playlist-detail-row-touch := TouchArea {
                                    clicked => { root.row-activated(row.kind, row.source_index); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 8px;
                                    padding-top: row.is_header ? 6px : 8px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        spacing: 3px;
                                        Text { text: row.title; color: row.is_header ? #7fc7e8 : #f5f7fb; font-size: row.is_header ? 12px : 15px; font-weight: row.is_header ? 700 : 400; overflow: elide; }
                                        if !row.is_header: Text { text: row.subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                    }
                                    if row.action_label != "": Button {
                                        text: row.action_label;
                                        clicked => { root.row-action-requested(row.kind, row.source_index, row.action_label); }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-route == "downloads": Rectangle {
                    border-color: #2b3038;
                    border-width: 1px;
                    border-radius: 6px;
                    background: #171a1f;

                    VerticalLayout {
                        padding: 18px;
                        spacing: 8px;
                        Text {
                            text: root.current-route == "home" ? "Home will surface albums, playlists, and history." :
                                root.current-route == "library" ? "Library browsing will land here after the local index is wired." :
                                root.current-route == "playlists" ? "Playlist list and detail routes will land here." :
                                "Downloads and offline cache controls will land here.";
                            color: #b8c0cc;
                            font-size: 14px;
                            overflow: elide;
                        }
                    }
                }

                if root.current-route == "player": Rectangle {
                    border-color: root.player-accent;
                    border-width: 1px;
                    border-radius: 6px;
                    background: root.player-surface;

                    HorizontalLayout {
                        padding: 16px;
                        spacing: 18px;

                        VerticalLayout {
                            spacing: 12px;
                            width: 330px;
                            Image {
                                source: root.now-playing-art;
                                image-fit: contain;
                                height: 280px;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Button { text: root.now-playing-favorite ? "Unfavorite" : "Favorite"; clicked => { root.now-playing-favorite-requested(); } }
                                Button { text: "Details"; clicked => { root.show-track-details = !root.show-track-details; } }
                                Button { text: "..."; clicked => { root.show-player-menu = !root.show-player-menu; } }
                            }
                            if root.show-player-menu: Rectangle {
                                height: 78px;
                                border-color: #343b46;
                                border-width: 1px;
                                border-radius: 6px;
                                background: #101318;
                                VerticalLayout {
                                    padding: 8px;
                                    spacing: 6px;
                                    Button { text: "Go To Artist"; clicked => { root.now-playing-link-requested("artist"); } }
                                    Button { text: "Go To Album"; clicked => { root.now-playing-link-requested("album"); } }
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 12px;
                            Text { text: root.now-playing-title; color: #f5f7fb; font-size: 26px; font-weight: 700; overflow: elide; }
                            HorizontalLayout {
                                spacing: 8px;
                                Button { text: root.now-playing-artist == "" ? "Artist" : root.now-playing-artist; clicked => { root.now-playing-link-requested("artist"); } }
                                Button { text: root.now-playing-album == "" ? "Album" : root.now-playing-album; clicked => { root.now-playing-link-requested("album"); } }
                            }
                            Text { text: "Year " + root.now-playing-year + "  -  " + root.now-playing-codec-line; color: #9ba7b5; font-size: 13px; overflow: elide; }
                            Text { text: root.playback-status-text; color: #7fc7e8; font-size: 13px; overflow: elide; }

                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: root.playback-elapsed-text; color: #9ba7b5; width: 42px; vertical-alignment: center; }
                                Slider {
                                    minimum: 0;
                                    maximum: 100;
                                    value <=> root.playback-progress;
                                    released(value) => { root.playback-seek-requested(value); }
                                }
                                Text { text: root.playback-duration-text; color: #9ba7b5; width: 48px; vertical-alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                PlayerIconButton { label: "<<"; clicked => { root.playback-previous-requested(); } }
                                if root.playback-is-playing: PlayerIconButton { label: "||"; active: true; clicked => { root.playback-pause-requested(); } }
                                if !root.playback-is-playing: PlayerIconButton { label: ">"; active: true; clicked => { root.playback-resume-requested(); } }
                                PlayerIconButton { label: ">>"; clicked => { root.playback-next-requested(); } }
                                PlayerIconButton { label: "Shuffle"; button-width: 74px; clicked => { root.playback-shuffle-requested(); } }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                Text { text: "Rating"; color: #9ba7b5; vertical-alignment: center; }
                                Button { text: root.now-playing-rating >= 1 ? "*" : "-"; clicked => { root.now-playing-rating-requested(1); } }
                                Button { text: root.now-playing-rating >= 2 ? "*" : "-"; clicked => { root.now-playing-rating-requested(2); } }
                                Button { text: root.now-playing-rating >= 3 ? "*" : "-"; clicked => { root.now-playing-rating-requested(3); } }
                                Button { text: root.now-playing-rating >= 4 ? "*" : "-"; clicked => { root.now-playing-rating-requested(4); } }
                                Button { text: root.now-playing-rating >= 5 ? "*" : "-"; clicked => { root.now-playing-rating-requested(5); } }
                            }

                            HorizontalLayout {
                                spacing: 14px;
                                VerticalLayout {
                                    spacing: 6px;
                                    Text { text: "Up Next"; color: #f5f7fb; font-size: 15px; font-weight: 700; }
                                    Rectangle {
                                        height: 132px;
                                        border-color: #2b3038;
                                        border-width: 1px;
                                        border-radius: 6px;
                                        background: #171a1f;
                                        ListView {
                                            for row in root.up-next-rows: Rectangle {
                                                height: 42px;
                                                background: up-next-touch.pressed ? #263241 : up-next-touch.has-hover ? #202833 : #171a1f;
                                                up-next-touch := TouchArea { clicked => { root.queue-row-activated(row.source_index); } }
                                                VerticalLayout {
                                                    padding-left: 10px;
                                                    padding-top: 5px;
                                                    spacing: 2px;
                                                    Text { text: row.title; color: #f5f7fb; font-size: 13px; overflow: elide; }
                                                    Text { text: row.subtitle; color: #9ba7b5; font-size: 11px; overflow: elide; }
                                                }
                                            }
                                        }
                                    }
                                }
                                VerticalLayout {
                                    spacing: 6px;
                                    Text { text: "Back To"; color: #f5f7fb; font-size: 15px; font-weight: 700; }
                                    Rectangle {
                                        height: 132px;
                                        border-color: #2b3038;
                                        border-width: 1px;
                                        border-radius: 6px;
                                        background: #171a1f;
                                        ListView {
                                            for row in root.back-to-rows: Rectangle {
                                                height: 42px;
                                                background: back-to-touch.pressed ? #263241 : back-to-touch.has-hover ? #202833 : #171a1f;
                                                back-to-touch := TouchArea { clicked => { root.queue-row-activated(row.source_index); } }
                                                VerticalLayout {
                                                    padding-left: 10px;
                                                    padding-top: 5px;
                                                    spacing: 2px;
                                                    Text { text: row.title; color: #f5f7fb; font-size: 13px; overflow: elide; }
                                                    Text { text: row.subtitle; color: #9ba7b5; font-size: 11px; overflow: elide; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                height: root.show-track-details ? 86px : 42px;
                                border-color: #2b3038;
                                border-width: 1px;
                                border-radius: 6px;
                                background: #171a1f;
                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 4px;
                                    Text { text: "Related tracks will appear here."; color: #9ba7b5; font-size: 13px; overflow: elide; }
                                    if root.show-track-details: Text { text: root.now-playing-details; color: #d8dee8; font-size: 12px; overflow: elide; }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 128px;
                    border-color: #2b3038;
                    border-width: 1px;
                    border-radius: 6px;
                    background: #15191f;

                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;

                        HorizontalLayout {
                            spacing: 10px;
                            Rectangle {
                                width: 58px;
                                height: 58px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: #364152;
                                background: #243041;
                                clip: true;

                                Image {
                                    source: root.now-playing-art;
                                    image-fit: cover;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }
                            VerticalLayout {
                                spacing: 3px;
                                Text { text: root.now-playing-title; color: #f5f7fb; font-size: 15px; font-weight: 700; overflow: elide; }
                                Text { text: root.now-playing-subtitle; color: #9ba7b5; font-size: 12px; overflow: elide; }
                                Text { text: root.playback-status-text; color: #7fc7e8; font-size: 11px; overflow: elide; }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: end;
                                PlayerIconButton { label: "<<"; clicked => { root.playback-previous-requested(); } }
                                if root.playback-is-playing: PlayerIconButton { label: "||"; active: true; clicked => { root.playback-pause-requested(); } }
                                if !root.playback-is-playing: PlayerIconButton { label: ">"; active: true; clicked => { root.playback-resume-requested(); } }
                                PlayerIconButton { label: ">>"; clicked => { root.playback-next-requested(); } }
                                PlayerIconButton { label: "Shuffle"; button-width: 74px; clicked => { root.playback-shuffle-requested(); } }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: root.playback-elapsed-text; color: #9ba7b5; width: 42px; vertical-alignment: center; }
                            Slider {
                                minimum: 0;
                                maximum: 100;
                                value <=> root.playback-progress;
                                released(value) => { root.playback-seek-requested(value); }
                            }
                            Text { text: root.playback-duration-text; color: #9ba7b5; width: 48px; vertical-alignment: center; }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "Volume"; color: #9ba7b5; width: 52px; vertical-alignment: center; }
                            Slider {
                                minimum: 0;
                                maximum: 100;
                                value <=> root.volume;
                                changed(value) => { root.volume-changed(value); }
                            }
                        }
                    }
                }
            }
        }
    }
}
